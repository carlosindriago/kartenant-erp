APP_NAME="Kartenant"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://kartenant.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# CRITICAL: Must be 'landlord' for multi-tenant architecture to work correctly
# This ensures all queries default to landlord database unless explicitly using tenant connection
DB_CONNECTION=landlord
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.kartenant.test

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=redis
CACHE_PREFIX=kartenant_
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@kartenant.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173

# Ports forwarding
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379

# Database Tenant (cada cliente tiene su propia BD)
DB_TENANT_CONNECTION=tenant
DB_TENANT_HOST=pgsql
DB_TENANT_PORT=5432
DB_TENANT_USERNAME=sail
DB_TENANT_PASSWORD=password

# --- Security / Alerts ---
# Enable Slack alerts for critical security events (e.g., make-superadmin)
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="Kartenant Security"
LOG_SLACK_EMOJI=:rotating_light:

# Gate the kartenant:make-superadmin command in production (default: disabled)
# Set to true ONLY for initial bootstrap, then remove/disable it.
ALLOW_SUPERADMIN_COMMAND=false
APP_MODE=saas
