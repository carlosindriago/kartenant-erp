includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:

    paths:
        - app/
        - config/
        - database/
        - routes/
        - tests/

    # Level 9 is the highest level
    level: 8

    excludePaths:
        - ./*/*/FileToBeExcluded.php
